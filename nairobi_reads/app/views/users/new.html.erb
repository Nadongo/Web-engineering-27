<div style="max-width: 500px; margin: 50px auto; text-align: center;">
  <h2>Sign Up for Nairobi Reads</h2>

  <%= form_with(model: @user, local: true) do |f| %>
    <div style="margin-bottom: 15px;">
      <%= f.label :name, "Full Name" %><br>
      <%= f.text_field :name, placeholder: "e.g., Wanjiku", required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :email, "Email Address" %><br>
      <%= f.email_field :email, placeholder: "e.g., wanjiku@example.com", required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :password, "Password" %><br>
      <%= f.password_field :password, required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :password_confirmation, "Confirm Password" %><br>
      <%= f.password_field :password_confirmation, required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :preferred_meeting_spot, "Preferred Meeting Spot (Optional)" %><br>
      <%= f.text_field :preferred_meeting_spot, placeholder: "e.g., Java House, Yaya Centre" %>
    </div>

    <div>
      <%= f.submit "Create Account" %>
    </div>
  <% end %>
</div>