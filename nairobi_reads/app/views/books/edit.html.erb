<div style="max-width: 500px; margin: 50px auto;">
  <h2>Edit Book Details</h2>

  <%= form_with(model: @book, local: true) do |f| %>
    <% if @book.errors.any? %>
      <div style="color: red; margin-bottom: 20px;">
        <h4>Please fix the following errors:</h4>
        <ul>
          <% @book.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="margin-bottom: 15px;">
      <%= f.label :title %><br>
      <%= f.text_field :title, required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :author %><br>
      <%= f.text_field :author, required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :category_id, "Category" %><br>
      <%= f.collection_select :category_id, Category.all, :id, :name %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :status, "Current Status" %><br>
      <%= f.select :status, Book.statuses.keys.map { |s| [s.titleize, s] } %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :description %><br>
      <%= f.text_area :description, rows: 4, required: true %>
    </div>

    <div>
      <%= f.submit "Update Book" %>
    </div>
  <% end %>

  <p style="margin-top: 20px;">
    <%= link_to "Cancel", book_path(@book) %> | <%= link_to "Back to Catalog", books_path %>
  </p>
</div>