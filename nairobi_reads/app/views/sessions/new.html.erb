<div style="max-width: 500px; margin: 50px auto; text-align: center;">
  <h2>Log In</h2>

  <%= form_with(scope: :session, url: login_path, local: true) do |f| %>
    <div style="margin-bottom: 15px;">
      <%= f.label :email, "Email Address" %><br>
      <%= f.email_field :email, required: true %>
    </div>

    <div style="margin-bottom: 15px;">
      <%= f.label :password, "Password" %><br>
      <%= f.password_field :password, required: true %>
    </div>

    <div>
      <%= f.submit "Log In" %>
    </div>
  <% end %>

  <hr class="my-4">
  <div class="d-grid gap-2 text-center">
    <p class="text-muted mb-2">Or log in instantly for testing:</p>
    
    <%= button_to 'Guest User Login', guest_login_path, method: :post, class: "btn btn-outline-secondary w-100" %>
    
    <%= button_to 'Admin Guest Login', admin_guest_login_path, method: :post, class: "btn btn-outline-dark w-100 mt-2" %>
  </div>

</div>